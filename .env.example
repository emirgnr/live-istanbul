# ── Metro Live Istanbul — ortam değişkenleri ─────────────────────────────────
# Kopyalayın:  cp .env.example .env   (hepsi opsiyonel; varsayılanlarla da çalışır)

# ── Frontend (VITE_ önekli değişkenler tarayıcıya gömülür) ────────────────────
# Canlı sefer backend'inin taban URL'i.
#   - Dev'de BOŞ bırakın: "/api" istekleri Vite proxy ile yerel backend'e gider.
#   - Prod'da (GitHub Pages) ayrı barındırılan backend'in tam URL'i (ör. https://metro-api.ornek.com)
VITE_API_BASE_URL=

# ── Backend (server/) ─────────────────────────────────────────────────────────
SERVER_PORT=3001
# metro.istanbul'a çıkış hızı (token-bucket)
UPSTREAM_RATE_PER_SEC=4
UPSTREAM_BURST=8
# Aynı (durak,yön) yanıt cache süresi (ms) — mimari kararı ~10 sn
RESPONSE_CACHE_TTL_MS=10000
# Taze session+kod yeniden kullanımı (ms)
SESSION_TTL_MS=1200000
# CORS: "*" ya da virgülle ayrık origin listesi (prod'da frontend origin'inizi verin)
CORS_ORIGIN=*
# Express trust proxy: false | true | hop sayısı (sadece gerçek ters proxy arkasındaysanız)
TRUST_PROXY=false
# Log seviyesi: error | warn | info | debug
LOG_LEVEL=info
