{
  "name": "metro-live-istanbul",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Metro Live Istanbul — realistic real-time/simulated positions of Istanbul metro & Marmaray trains",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,green \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start:api": "tsx server/index.ts",
    "seed:refresh": "tsx server/scripts/refresh-seed.ts",
    "verify:geo": "node scripts/data/verify-geo.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p server/tsconfig.json",
    "test:server": "node --import tsx --test server/test/*.test.ts",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\""
  },
  "dependencies": {
    "@turf/turf": "^7.3.5",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "i18next": "^26.3.3",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "@eslint/js": "^10.0.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
